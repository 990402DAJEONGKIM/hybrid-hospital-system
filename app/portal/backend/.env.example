# DB 연결 주소 (로컬: localhost, AWS: Aurora 엔드포인트로 교체)
DATABASE_URL=postgresql://postgres:password@localhost:5432/hospital

# JWT 서명 키 — 충분히 긴 랜덤 문자열로 교체
JWT_SECRET=change-this-to-a-long-random-secret

# 프론트엔드와 맞춰야 하는 API 키
API_KEY=change-this-api-key

# 로컬 개발: false / 운영(HTTPS): true
COOKIE_SECURE=true
