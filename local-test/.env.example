# ============================================================
# 로컬 테스트 전용 환경변수 템플릿
# 사용법: cp .env.example .env  →  필요 시 값 변경 후 사용
# 주의:   .env 파일은 절대 git commit 금지 (.gitignore에 등록됨)
# ============================================================

# ── DB ───────────────────────────────────────────────────────
# AWS RDS와 동일한 cloud 스키마 사용 (patient_id_hash 컬럼)
DB_MODE=cloud
POSTGRES_PASSWORD=localtest1234

# ── JWT / API 인증 ───────────────────────────────────────────
# 로컬 전용 값 — 실제 배포 시 반드시 교체
JWT_SECRET=local-jwt-secret-change-in-production-must-be-32chars
JWT_SECRET_PREVIOUS=
API_KEY=local-api-key-1234

# ── 환자 식별자 해싱 ─────────────────────────────────────────
HASH_SALT=local-hash-salt-change-in-production

# ── CORS / 쿠키 ──────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1,*
# HTTP 로컬 환경이므로 false (HTTPS 필요 없음)
COOKIE_SECURE=false

# ── AWS SES 이메일 ────────────────────────────────────────────
# 미설정 시 ses.py가 이메일 발송을 자동 생략 (로컬 정상 동작)
SES_FROM_EMAIL=
ADMIN_EMAIL=
AWS_REGION=ap-northeast-2

# ── Vault ────────────────────────────────────────────────────
# 미설정 시 vault_loader가 즉시 반환 → 위 환경변수를 직접 사용
VAULT_ADDR=
VAULT_TOKEN=
