<group name="local,sudo,after_hours,fim">
 
  <!-- ───────────────────────────────────── -->
  <!-- sudo 사용 탐지 -->
  <!-- ───────────────────────────────────── -->
 
  <!-- 기본 sudo 실행 -->
  <rule id="100001" level="6">
    <if_sid>5402</if_sid>
    <description>sudo 명령어 실행 탐지 - 사용자: $(srcuser)</description>
    <group>sudo_usage,privilege_escalation</group>
  </rule>
 
  <!-- 업무 시간 외 sudo -->
  <rule id="100002" level="8">
    <if_sid>100001</if_sid>
    <time>00:00 - 06:00</time>
    <description>업무 시간 외 sudo 사용 탐지 - 사용자: $(srcuser)</description>
    <group>after_hours,sudo_usage</group>
  </rule>
 
  <!-- root 권한 획득 -->
  <!-- dstuser는 static field라 안됨 → match로 변경 -->
  <rule id="100003" level="10">
    <if_sid>5402</if_sid>
    <match>USER=root</match>
    <description>root 권한 전환 탐지 - 사용자: $(srcuser)</description>
    <group>sudo_usage,root_access,privilege_escalation</group>
  </rule>
 
  <!-- ───────────────────────────────────── -->
  <!-- 파일 권한 변경 -->
  <!-- if_group>syscheck 대신 if_sid 사용, field name 대신 match 사용 -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100004" level="8">
    <if_sid>550,554,553</if_sid>
    <field name="changed_attributes">permission</field>
    <description>파일 권한 변경 탐지</description>
    <group>fim,permission_change</group>
  </rule>
 
  <!-- ───────────────────────────────────── -->
  <!-- 중요 시스템 파일 변조 -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100005" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="file">/etc/passwd</field>
    <description>중요 파일 변조 탐지 - /etc/passwd</description>
    <group>fim,critical_file</group>
  </rule>
 
  <rule id="100006" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="file">/etc/shadow</field>
    <description>중요 파일 변조 탐지 - /etc/shadow</description>
    <group>fim,critical_file</group>
  </rule>
 
  <rule id="100007" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="file">/etc/sudoers$</field>
    <description>sudoers 파일 변경 탐지 - 권한 상승 의심</description>
    <group>fim,privilege_escalation</group>
  </rule>
 
  <!-- sudoers.d persistence -->
  <rule id="100019" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="file">/etc/sudoers.d/</field>
    <description>sudoers.d 파일 변경 탐지 - persistence 의심</description>
    <group>fim,privilege_escalation,persistence</group>
  </rule>
 
  <!-- SSH 설정 변경 -->
  <rule id="100008" level="10">
    <if_sid>550,554,553</if_sid>
    <field name="file">/etc/ssh/sshd_config</field>
    <description>SSH 설정 변경 탐지</description>
    <group>fim,ssh</group>
  </rule>
 
</group>
 
<group name="web,nginx,attack,bruteforce,persistence">
 
  <!-- ───────────────────────────────────── -->
  <!-- 웹쉘 업로드 탐지 -->
  <!-- if_sid 554 = 파일 추가, field name event 대신 if_sid로 구분 -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100010" level="12">
    <if_sid>554</if_sid>
    <match>/var/www/</match>
    <regex>\.php$|\.phtml$|\.phar$|\.sh$|\.py$|\.pl$</regex>
    <description>웹 서버 경로에 실행 파일 생성됨 (웹쉘 의심)</description>
    <group>web_attack,fim,webshell</group>
  </rule>
 
  <rule id="100022" level="12">
    <if_sid>554</if_sid>
    <match>/usr/share/nginx/</match>
    <regex>\.php$|\.phtml$|\.phar$|\.sh$|\.py$|\.pl$</regex>
    <description>nginx 경로에 실행 파일 생성됨 (웹쉘 의심)</description>
    <group>web_attack,fim,webshell</group>
  </rule>
 
  <!-- ───────────────────────────────────── -->
  <!-- Nginx Recon -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100011" level="10" frequency="20" timeframe="60">
    <if_matched_sid>31101</if_matched_sid>
    <match>404</match>
    <description>1분 내 20회 이상 404 발생 - 웹 스캔 의심</description>
    <group>web_scan,reconnaissance</group>
  </rule>
 
  <!-- ───────────────────────────────────── -->
  <!-- SQL Injection -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100012" level="12">
    <if_sid>31106</if_sid>
    <match>union select|select from|insert into|drop table|or 1=1</match>
    <description>SQL Injection 공격 패턴 탐지</description>
    <group>web_attack,sql_injection</group>
  </rule>
 
  <!-- ───────────────────────────────────── -->
  <!-- SSH Brute Force -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100013" level="10" frequency="5" timeframe="30">
    <if_matched_sid>5712</if_matched_sid>
    <description>30초 내 SSH 로그인 실패 5회 이상 - Brute Force 의심</description>
    <group>authentication_failed,bruteforce</group>
  </rule>
 
  <!-- ───────────────────────────────────── -->
  <!-- 중요 실행 파일 변조 -->
  <!-- if_sid 550 = 파일 수정 -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100014" level="9">
    <if_sid>550</if_sid>
    <match>/usr/bin/</match>
    <description>시스템 실행 파일 변조 탐지 (/usr/bin) - 백도어 의심</description>
    <group>fim,rootkit,persistence</group>
  </rule>
 
  <rule id="100015" level="12">
    <if_sid>550,554</if_sid>
    <match>authorized_keys</match>
    <description>SSH authorized_keys 변경 탐지</description>
    <group>fim,ssh_attack,persistence</group>
  </rule>
 
  <!-- ───────────────────────────────────── -->
  <!-- SSH Persistence -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100016" level="9">
    <if_sid>550</if_sid>
    <match>/usr/sbin/</match>
    <description>관리자 실행 파일 변조 탐지 (/usr/sbin) - 백도어 의심</description>
    <group>fim,rootkit,persistence</group>
  </rule>
 
  <!-- ───────────────────────────────────── -->
  <!-- 업무 시간 외 로그인 -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100017" level="10">
    <if_sid>5715</if_sid>
    <time>00:00 - 06:00</time>
    <description>업무 시간 외 SSH 로그인 성공 - 계정 탈취 의심</description>
    <group>after_hours,authentication_success</group>
  </rule>
 
  <!-- ───────────────────────────────────── -->
  <!-- 신규 계정 생성 -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100018" level="12">
    <if_sid>5902</if_sid>
    <description>새로운 사용자 계정 생성 탐지 - persistence 의심</description>
    <group>account_management,privilege_escalation,persistence</group>
  </rule>
 
  <!-- ───────────────────────────────────── -->
  <!-- systemd persistence -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100020" level="13">
    <if_sid>554,550</if_sid>
    <match>/etc/systemd/system/</match>
    <description>systemd 서비스 파일 변경 탐지 (/etc) - persistence 의심</description>
    <group>fim,persistence,systemd</group>
  </rule>
 
  <rule id="100021" level="9">
    <if_sid>554,550</if_sid>
    <match>/usr/lib/systemd/system/</match>
    <description>systemd 서비스 파일 변경 탐지 (/usr/lib) - 패키지 변경 가능성 있음</description>
    <group>fim,systemd</group>
  </rule>
 
  <!-- ───────────────────────────────────── -->
  <!-- cron persistence -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100023" level="12">
    <if_sid>550,554</if_sid>
    <match>/etc/crontab</match>
    <description>crontab 파일 변경 탐지 - persistence 의심</description>
    <group>fim,persistence,cron</group>
  </rule>
 
  <rule id="100024" level="12">
    <if_sid>550,554</if_sid>
    <match>/etc/cron.d/</match>
    <description>cron.d 파일 변경 탐지 - persistence 의심</description>
    <group>fim,persistence,cron</group>
  </rule>
 
  <rule id="100025" level="12">
    <if_sid>550,554</if_sid>
    <match>/etc/cron.</match>
    <description>cron 주기 디렉토리 파일 변경 탐지 - persistence 의심</description>
    <group>fim,persistence,cron</group>
  </rule>
 
  <!-- ───────────────────────────────────── -->
  <!-- /usr/local/bin persistence -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100026" level="10">
    <if_sid>550,554</if_sid>
    <match>/usr/local/bin/</match>
    <description>시스템 실행 파일 변조 탐지 (/usr/local/bin) - 백도어 의심</description>
    <group>fim,rootkit,persistence</group>
  </rule>
 
  <!-- ───────────────────────────────────── -->
  <!-- rc.local persistence -->
  <!-- ───────────────────────────────────── -->
 
  <rule id="100027" level="12">
    <if_sid>550,554</if_sid>
    <match>/etc/rc.local</match>
    <description>rc.local 변경 탐지 - persistence 의심</description>
    <group>fim,persistence</group>
  </rule>
 
  <!-- if_sid 554 = 파일 추가 -->
  <rule id="100028" level="12">
    <if_sid>554</if_sid>
    <match>/usr/bin/</match>
    <description>시스템 경로에 신규 실행 파일 생성 탐지 (/usr/bin) - 백도어 의심</description>
    <group>fim,rootkit,persistence</group>
  </rule>
 
  <rule id="100029" level="12">
    <if_sid>554</if_sid>
    <match>/usr/sbin/</match>
    <description>관리자 경로에 신규 실행 파일 생성 탐지 (/usr/sbin) - 백도어 의심</description>
    <group>fim,rootkit,persistence</group>
  </rule>
 
</group>