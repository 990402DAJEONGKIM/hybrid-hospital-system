<ossec_config>

  <!-- ======================================= -->
  <!-- 글로벌 설정                              -->
  <!-- ======================================= -->
  <global>
    <jsonout_output>yes</jsonout_output>
    <alerts_log>yes</alerts_log>
    <logall>no</logall>
    <logall_json>no</logall_json>
    <email_notification>no</email_notification>
    <smtp_server>localhost</smtp_server>
    <email_from>wazuh@localhost</email_from>
    <email_to>root@localhost</email_to>
    <email_maxperhour>12</email_maxperhour>
    <email_log_source>alerts.log</email_log_source>
    <agents_disconnection_time>10m</agents_disconnection_time>
    <agents_disconnection_alert_time>0</agents_disconnection_alert_time>
  </global>

  <!-- ======================================= -->
  <!-- 알림 레벨                               -->
  <!-- ======================================= -->
  <alerts>
    <log_alert_level>3</log_alert_level>
    <email_alert_level>12</email_alert_level>
  </alerts>

  <!-- ======================================= -->
  <!-- Agent 수신 설정                          -->
  <!-- ======================================= -->
  <remote>
    <connection>secure</connection>
    <port>1514</port>
    <protocol>tcp</protocol>
    <queue_size>131072</queue_size>
  </remote>

  <!-- ======================================= -->
  <!-- 룰셋 & 디코더                            -->
  <!-- ======================================= -->
  <ruleset>
    <decoder_dir>ruleset/decoders</decoder_dir>
    <rule_dir>ruleset/rules</rule_dir>
    <rule_dir>etc/rules</rule_dir> 
    <rule_exclude>0215-policy_rules.xml</rule_exclude>
    <list>etc/lists/audit-keys</list>
    <list>etc/lists/amazon/aws-eventnames</list>
    <list>etc/lists/security-eventchannel</list>
  </ruleset>

  <!-- ======================================= -->
  <!-- FIM (파일 무결성 모니터링)                -->
  <!-- ======================================= -->
  <syscheck>
    <disabled>no</disabled>
    <frequency>3600</frequency>
    <scan_on_start>yes</scan_on_start>

    <!-- realtime 모니터링 -->
    <directories realtime="yes" check_all="yes">/etc</directories>
    <directories realtime="yes" check_all="yes" report_changes="yes">/var/ossec/etc</directories>
   

    <!-- 주기 모니터링 (6시간) -->
    <directories check_all="yes">/usr/bin,/usr/sbin</directories>

    <!-- 무시 목록 -->
    <ignore>/etc/mtab</ignore>
    <ignore>/etc/hosts.deny</ignore>
    <ignore>/etc/mail/statistics</ignore>
    <ignore>/etc/random-seed</ignore>
    <ignore>/etc/adjtime</ignore>
    <ignore>/etc/resolv.conf</ignore>
    <ignore>/var/ossec/logs/alerts</ignore>
    <ignore>/var/ossec/logs/archives</ignore>

    <skip_nfs>yes</skip_nfs>
  </syscheck>

  <!-- ======================================= -->
  <!-- Rootcheck                               -->
  <!-- ======================================= -->
  <rootcheck>
    <disabled>no</disabled>
    <check_files>yes</check_files>
    <check_trojans>yes</check_trojans>
    <check_dev>yes</check_dev>
    <check_sys>yes</check_sys>
    <check_pids>yes</check_pids>
    <check_ports>yes</check_ports>
    <check_if>yes</check_if>
    <frequency>43200</frequency>
    <rootkit_files>etc/shared/rootkit_files.txt</rootkit_files>
    <rootkit_trojans>etc/shared/rootkit_trojans.txt</rootkit_trojans>
    <system_audit>etc/shared/system_audit_rcl.txt</system_audit>
    <system_audit>etc/shared/system_audit_ssh.txt</system_audit>
    <system_audit>etc/shared/cis_debian_linux_rcl.txt</system_audit>
    <ignore>/bin/diff</ignore>
    <ignore>/bin/ls</ignore>
  </rootcheck>

  <!-- ======================================= -->
  <!-- 취약점 탐지                              -->
  <!-- ======================================= -->
  <vulnerability-detection>
    <enabled>yes</enabled>
    <index-status>yes</index-status>
    <feed-update-interval>60m</feed-update-interval>
  </vulnerability-detection>

  <!-- ======================================= -->
  <!-- 로그 수집 (journald 제외 - 4.7.5 미지원) -->
  <!-- ======================================= -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/auth.log</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/ossec/logs/ossec.log</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/filebeat/filebeat</location>
  </localfile>

  <!-- ======================================= -->
  <!-- Slack 연동 (level 10 이상)               -->
  <!-- ======================================= -->
  {% set _webhook = lookup('amazon.aws.aws_ssm', '/wazuh/slack-alarm-webhook', region=aws_region, decrypt=True) %}
  {% if _webhook %}
  <integration>
    <name>slack</name>
    <hook_url>{{ _webhook }}</hook_url>
    <level>10</level>
    <alert_format>json</alert_format>
  </integration>
  {% endif %}

<!-- ======================================= -->
<!-- Agent 등록 설정                          -->
<!-- ======================================= -->
  <auth>
    <disabled>no</disabled>
    <port>1515</port>
    <use_source_ip>no</use_source_ip>
    <purge>yes</purge>
    <use_password>no</use_password>
    <ssl_verify_host>no</ssl_verify_host>
    <ssl_manager_cert>etc/sslmanager.cert</ssl_manager_cert>
    <ssl_manager_key>etc/sslmanager.key</ssl_manager_key>
    <ssl_auto_negotiate>no</ssl_auto_negotiate>
  </auth>




  <!-- ======================================= -->
  <!-- AWS 로그 수집 통합 (CloudWatch + S3)     -->
  <!-- ISMS-P 2.9.1: 로그 수집/보존            -->
  <!-- ======================================= -->
  <wodle name="aws-s3">
    <disabled>no</disabled>
    <interval>5m</interval>
    <run_on_start>yes</run_on_start>
    <skip_on_error>yes</skip_on_error>
    <!-- RDS pgaudit -->
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/rds/cluster/aws-aurora-01/postgresql</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <!-- RDS Proxy -->
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/rds/proxy/aws-rds-proxy-01</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <!-- VPN -->
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/vendedlogs/vpn/aws-vpn-01</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/vendedlogs/vpn/aws-vpn-gcp</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <!-- Lambda 로그 수집 (CloudWatch Logs) - 260610 김강환 -->
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-dump</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/mzclinic-keycloak-db-rotator</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-wazuh-lambda-agent-cleanup</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-wazuh-report-fn-01</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-jwt-rotator</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-cost-monthly-report</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-wazuh-lambda-indexer-recovery</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-vault-rotator</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-ecs-db-rotator</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-cost-gcp-collector</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-cost-to-kb</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-cost-chat</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-wazuh-lambda-recovery</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-cost-anomaly</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-wazuh-lambda-slack-notify</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-cost-aws-collector</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-rotation</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-cost-onprem-calc</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-cost-dashboard</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>
    <service type="cloudwatchlogs">
      <aws_log_groups>/aws/lambda/aws-lambda-ecs-redeployer</aws_log_groups>
      <regions>{{ aws_region }}</regions>
    </service>



    <!-- CloudTrail -->
    <bucket type="cloudtrail">
      <name>aws-k2p-storage-01</name>
      <path>cloudtrail</path>
    </bucket>
    <!-- GuardDuty -->
    <bucket type="guardduty">
      <name>aws-k2p-storage-01</name>
      <path>guardduty</path>
    </bucket>
    <!-- VPC Flow Logs -->
    <bucket type="vpcflow">
      <name>aws-k2p-storage-01</name>
      <path>flowlogs</path>
    </bucket>
    <!-- WAF BLOCK 이벤트 -->
    <bucket type="custom">
      <name>aws-k2p-storage-01</name>
      <path>waf/</path>
      <only_logs_after>2026-JUN-01</only_logs_after>
      <regions>{{ aws_region }}</regions>
    </bucket>
     <!-- ALB  -->
    <bucket type="alb">
      <name>aws-k2p-alb-01</name>
      <path>alb/</path>
    </bucket>
  </wodle>

  
  <!-- ======================================= -->
  <!-- Indexer 연결 설정 (취약점 탐지용)        -->
  <!-- ======================================= -->
  <indexer>
    <enabled>yes</enabled>
    <hosts>
      <host>https://{{ wazuh_indexer_ip }}:9200</host>
    </hosts>
    <ssl>
      <certificate_authorities>
        <ca>/etc/filebeat/certs/root-ca.pem</ca>
      </certificate_authorities>
      <certificate>/etc/filebeat/certs/{{ wazuh_cert_name }}.pem</certificate>
      <key>/etc/filebeat/certs/{{ wazuh_cert_name }}-key.pem</key>
    </ssl>
  </indexer>


</ossec_config>
