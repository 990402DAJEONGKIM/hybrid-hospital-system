    <group name="cloudsql,audit,gcp,">

    <!-- Cloud SQL DB 접속 탐지 (ISMS-P 2.9.1) -->
    <rule id="100200" level="3">
        <decoded_as>json</decoded_as>
        <field name="action_type">^LOGIN$</field>
        <description>Cloud SQL DB 접속 — source_ip: $(source_ip)</description>
        <group>cloudsql,login,</group>
    </rule>

    <!-- Cloud SQL DB 접속 종료 -->
    <rule id="100201" level="3">
        <decoded_as>json</decoded_as>
        <field name="action_type">^LOGOUT$</field>
        <description>Cloud SQL DB 접속 종료 — source_ip: $(source_ip)</description>
        <group>cloudsql,logout,</group>
    </rule>

    <!-- Cloud SQL 관리자 작업 (설정변경, 재시작 등) -->
    <rule id="100202" level="8">
        <decoded_as>json</decoded_as>
        <field name="action_type">^ADMIN_</field>
        <description>Cloud SQL 관리자 작업 탐지 — action: $(action_type)</description>
        <group>cloudsql,admin,</group>
    </rule>

    <!-- 예상치 못한 외부 IP 접속 (보안 이벤트) -->
    <rule id="100203" level="12">
        <if_sid>100200</if_sid>
        <field name="source_ip" negate="yes">^127\.|^172\.29\.</field>
        <description>Cloud SQL 외부 IP 접속 탐지 — source_ip: $(source_ip)</description>
        <group>cloudsql,login,suspicious,</group>
    </rule>

    <rule id="100204" level="0">
        <if_sid>100200</if_sid>
        <field name="source_ip">^127\.0\.0\.1$</field>
        <description>Cloud SQL 내부 복제 연결 — 무시</description>
        <group>cloudsql,noise,</group>
    </rule>

    <rule id="100205" level="0">
        <if_sid>100201</if_sid>
        <field name="source_ip">^127\.0\.0\.1$</field>
        <description>Cloud SQL 내부 복제 종료 — 무시</description>
        <group>cloudsql,noise,</group>
    </rule>

    <!-- gcp-rds-proxy-01 내부 복제 연결 — 무시 -->
    <rule id="100206" level="0">
        <if_sid>100200</if_sid>
        <field name="source_ip">^10\.10\.1\.26$</field>
        <description>gcp-rds-proxy-01 내부 연결 — 무시</description>
        <group>cloudsql,noise,</group>
    </rule>

    </group>