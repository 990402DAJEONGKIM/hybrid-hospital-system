<!-- =========================================================
     ecs_rules.xml
     ECS FastAPI 감사 로그 탐지 룰

     ECS 로그 흐름:
       FastAPI stdout → Docker json-file → Vector 파싱
       → /var/log/ecs-fastapi-audit.log → Wazuh agent
       → 86600(Suricata json decoder) → 100700(ECS 베이스룰)

     onprem과 구분 기준:
       ECS 로그: source_type: docker_logs 필드 있음
       onprem 로그: source_type 필드 없음

     ISMS-P 2.9.1 개인정보처리시스템 접근기록
     수정 260611 김강환
     ========================================================= -->
<group name="ecs,fastapi,">

  <!-- ECS FastAPI 감사 로그 베이스 룰 -->
  <!-- 86600(Suricata) child + source_type: docker_logs 로 onprem 100600과 구분 -->
  <!-- 수정 260611 김강환 -->
  <rule id="100700" level="3">
    <if_sid>86600</if_sid>
    <field name="event_type">^fastapi_audit$</field>
    <field name="source_type">^docker_logs$</field>
    <description>ECS FastAPI — $(action_type) IP: $(source_ip) 응답: $(result_code)</description>
    <group>ecs,fastapi,audit_archive,</group>
  </rule>
  <!-- ECS FastAPI 인증 실패 401/403 탐지 -->
  <!-- ISMS-P 2.5.1 접근통제, MITRE T1110 브루트포스 -->
  <!-- 수정 260611 김강환 -->
  <rule id="100701" level="5">
    <if_sid>100700</if_sid>
    <field name="result_code">^401$|^403$</field>
    <description>ECS FastAPI 로그인 실패 — IP: $(source_ip) 경로: $(path)</description>
    <group>ecs,fastapi,authentication_failed,</group>
    <mitre><id>T1110</id></mitre>
  </rule>

  <!-- ECS FastAPI 브루트포스 탐지 -->
  <!-- 120초 내 동일 IP 8회 인증 실패 -->
  <!-- ISMS-P 2.5.1 접근통제, MITRE T1110.001 패스워드 추측 -->
  <!-- 수정 260611 김강환 -->
  <rule id="100702" level="10" frequency="8" timeframe="120">
    <if_matched_sid>100701</if_matched_sid>
    <same_field>source_ip</same_field>
    <description>ECS FastAPI 브루트포스 의심 — 공격 IP: $(source_ip)</description>
    <group>ecs,fastapi,brute_force,</group>
    <mitre><id>T1110.001</id></mitre>
  </rule>

  <!-- ECS FastAPI 정상 응답 억제 - 추가 260612 김강환 -->
  <rule id="100703" level="0">
    <if_sid>100700</if_sid>
    <field name="result_code">^2</field>
    <description>ECS FastAPI 정상 응답 — 무시</description>
    <group>noise</group>
  </rule>
  <!-- ECS FastAPI 500 에러 탐지 - 추가 260612 김강환 -->
  <rule id="100704" level="7">
    <if_sid>100700</if_sid>
    <field name="result_code">^5</field>
    <description>ECS FastAPI 서버 오류 — IP: $(source_ip) 경로: $(path) 응답: $(result_code)</description>
    <group>ecs,fastapi,error</group>
  </rule>
</group>