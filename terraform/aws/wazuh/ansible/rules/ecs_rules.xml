<group name="ecs,fastapi,">

  <!-- 베이스 룰: ECS FastAPI 감사 로그 수신 -->
  <!-- ECS는 Vector가 순수 JSON 저장 → 86600 미매칭 → decoded_as>json 직접 사용 -->
  <rule id="100700" level="3">
    <decoded_as>json</decoded_as>
    <field name="event_type">^fastapi_audit$</field>
    <description>ECS FastAPI 감사 로그 - $(method) $(path) $(result_code)</description>
    <group>ecs,fastapi,audit_archive,</group>
  </rule>

  <!-- 인증 실패 401/403 탐지 -->
  <!-- MITRE T1110 브루트포스 -->
  <rule id="100701" level="5">
    <if_sid>100700</if_sid>
    <field name="result_code">^401$|^403$</field>
    <description>ECS FastAPI 인증 실패 - ip: $(source_ip) path: $(path)</description>
    <group>ecs,fastapi,authentication_failed,</group>
    <mitre><id>T1110</id></mitre>
  </rule>

  <!-- 브루트포스: 120초 내 동일 IP 8회 인증 실패 -->
  <!-- Wazuh 공식 SSH 브루트포스 룰(5712) 기준 적용 - frequency=8, timeframe=120 -->
  <!-- level=10 — Slack #wazuh-alarm 알림 발송 -->
  <!-- MITRE T1110.001 패스워드 추측 -->
  <rule id="100702" level="10" frequency="8" timeframe="120">
    <if_matched_sid>100701</if_matched_sid>
    <same_srcip/>
    <description>ECS FastAPI Brute Force 의심 - ip: $(source_ip)</description>
    <group>ecs,fastapi,brute_force,</group>
    <mitre><id>T1110.001</id></mitre>
  </rule>

</group>