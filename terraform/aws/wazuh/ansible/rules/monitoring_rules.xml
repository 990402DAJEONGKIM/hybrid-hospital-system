<!-- =========================================================
     monitoring_rules.xml
     모니터링 서버 전용 탐지 룰
     대상: Grafana, Prometheus, Nginx(Keycloak)

     룰 ID 범위:
       100800~100809  Grafana 탐지
       100810~100819  Prometheus 탐지
       100820~100829  Nginx(Keycloak) 탐지

     ISMS-P 관련 조항:
       2.9.1 로그관리
       2.11.1 사고 예방 및 대응
     추가 260612 김강환
     ========================================================= -->

<group name="monitoring,">

  <!-- =========================================================
       Grafana 탐지
       수집: journald grafana-server.service
       ========================================================= -->

  <!-- Grafana 서비스 오류 베이스 룰 -->
  <rule id="100800" level="7">
    <if_sid>1002</if_sid>
    <program_name>grafana</program_name>
    <match>level=error</match>
    <description>Grafana 서비스 오류 발생 — 즉시 확인 필요</description>
    <group>monitoring,grafana,error,</group>
  </rule>

  <!-- Grafana 서비스 다운 탐지 -->
  <rule id="100801" level="12">
    <if_sid>2101</if_sid>
    <match>grafana</match>
    <description>Grafana 서비스 중단 — 대시보드 접근 불가 상태</description>
    <group>monitoring,grafana,down,</group>
  </rule>

  <!-- Grafana 로그인 실패 탐지 -->
  <rule id="100802" level="5">
    <if_sid>1002</if_sid>
    <program_name>grafana</program_name>
    <match>Failed to authenticate</match>
    <description>Grafana 인증 실패 — 사용자 토큰 오류 또는 로그인 실패</description>
    <group>monitoring,grafana,authentication_failed,</group>
  </rule>

  <!-- Grafana 로그인 실패 억제 — 세션 만료 정상 동작 -->
  <rule id="100803" level="0">
    <if_sid>100802</if_sid>
    <match>user token not found</match>
    <description>Grafana 세션 만료 — 무시</description>
    <group>noise</group>
  </rule>

  <!-- Grafana 브루트포스 탐지 — 2분 내 동일 IP 8회 인증 실패 -->
  <rule id="100804" level="10" frequency="8" timeframe="120">
    <if_matched_sid>100802</if_matched_sid>
    <description>Grafana 브루트포스 의심 — 짧은 시간 내 반복 인증 실패</description>
    <group>monitoring,grafana,brute_force,</group>
    <mitre><id>T1110</id></mitre>
  </rule>

  <!-- =========================================================
       Prometheus 탐지
       수집: journald prometheus.service
       ========================================================= -->

  <!-- Prometheus 서비스 오류 베이스 룰 -->
  <rule id="100810" level="7">
    <if_sid>1002</if_sid>
    <program_name>prometheus</program_name>
    <match>level=error</match>
    <description>Prometheus 서비스 오류 발생 — 메트릭 수집 이상 가능성</description>
    <group>monitoring,prometheus,error,</group>
  </rule>

  <!-- Prometheus 서비스 다운 탐지 -->
  <rule id="100811" level="12">
    <if_sid>2101</if_sid>
    <match>prometheus</match>
    <description>Prometheus 서비스 중단 — 전체 메트릭 수집 불가 상태</description>
    <group>monitoring,prometheus,down,</group>
  </rule>

  <!-- Prometheus scrape 실패 탐지 -->
  <rule id="100812" level="8">
    <if_sid>1002</if_sid>
    <program_name>prometheus</program_name>
    <match>scrape failed\|msg="Error scraping</match>
    <description>Prometheus 메트릭 수집 실패 — 대상 서버 응답 없음</description>
    <group>monitoring,prometheus,scrape_failed,</group>
  </rule>

  <!-- =========================================================
       Nginx(Keycloak) 탐지
       수집: /var/log/nginx/access.log
       ========================================================= -->

  <!-- ELB 헬스체크 억제 -->
  <rule id="100820" level="0">
    <if_sid>31101,31103</if_sid>
    <match>ELB-HealthChecker</match>
    <description>ELB 헬스체크 — 무시</description>
    <group>noise</group>
  </rule>

  <!-- Nginx 400 에러 탐지 -->
  <rule id="100821" level="5">
    <if_sid>31101</if_sid>
    <agent_list>050</agent_list>
    <description>모니터링 서버 Nginx 400 에러 — IP: $(srcip) URL: $(url)</description>
    <group>monitoring,nginx,web_error,</group>
  </rule>

  <!-- Nginx 브루트포스 탐지 — 2분 내 동일 IP 8회 400 에러 -->
  <rule id="100822" level="10" frequency="8" timeframe="120">
    <if_matched_sid>100821</if_matched_sid>
    <same_source_ip/>
    <description>모니터링 서버 Nginx 브루트포스 의심 — 공격 IP: $(srcip)</description>
    <group>monitoring,nginx,brute_force,</group>
    <mitre><id>T1110</id></mitre>
  </rule>

</group>