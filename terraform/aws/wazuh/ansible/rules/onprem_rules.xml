# onprem_rules.xml
<group name="onprem,fim,critical_file">

  <!-- ───────────────────────────────────── -->
  <!-- 온프레미스 FIM 탐지 -->
  <!-- ───────────────────────────────────── -->

  <rule id="100031" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="file">/etc/passwd</field>
    <description>온프레미스 /etc/passwd 변조 탐지</description>
    <group>fim,critical_file,onprem</group>
  </rule>

  <rule id="100032" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="file">/etc/shadow</field>
    <description>온프레미스 /etc/shadow 변조 탐지</description>
    <group>fim,critical_file,onprem</group>
  </rule>

  <rule id="100033" level="10">
    <if_sid>550,554,553</if_sid>
    <field name="file">/etc/ssh/sshd_config</field>
    <description>온프레미스 SSH 설정 변경 탐지</description>
    <group>fim,ssh,onprem</group>
  </rule>

  <rule id="100034" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="file">/etc/sudoers</field>
    <description>온프레미스 sudoers 변경 탐지</description>
    <group>fim,privilege_escalation,onprem</group>
  </rule>

  <rule id="100035" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="file">/home/mspadmin/hospital-db/docker-compose.yml</field>
    <description>온프레미스 hospital-db docker-compose.yml 변조 탐지</description>
    <group>fim,critical_file,onprem</group>
  </rule>

  <rule id="100036" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="file">/home/mspadmin/deidentification-api/docker-compose.yml</field>
    <description>온프레미스 deidentification-api docker-compose.yml 변조 탐지</description>
    <group>fim,critical_file,onprem</group>
  </rule>

  <!-- USB 저장장치 연결 탐지 -->
  <rule id="100039" level="12">
    <if_sid>1002</if_sid>
    <match>USB Mass Storage</match>
    <description>온프레미스 USB 저장장치 연결 — 데이터 유출 의심</description>
    <group>onprem,usb,insider_threat</group>
    <mitre><id>T1091</id></mitre>
  </rule>

  <!-- 업무 시간 외 온프레미스 SSH 접근 -->
  <rule id="100041" level="10">
    <if_sid>5715</if_sid>
    <time>09:00 - 00:00</time>
    <weekday>saturday,sunday</weekday>
    <field name="agent.name">onprem-mspserver</field>
    <description>업무 시간 외 온프레미스 SSH 접근</description>
    <group>onprem,after_hours,insider_threat</group>
    <mitre><id>T1078</id></mitre>
  </rule>



</group>