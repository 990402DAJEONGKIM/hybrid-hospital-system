# rds_rules.xml
<group name="rds,pgaudit,">

  <!-- RDS pgaudit 기본 탐지 (부모 룰) -->
  <rule id="100100" level="3">
    <location>Wazuh-AWS</location>
    <match>AUDIT: SESSION</match>
    <description>RDS pgaudit 감사 로그</description>
  </rule>

  <!-- DDL 탐지 -->
  <rule id="100101" level="10">
    <if_sid>100100</if_sid>
    <match>,DDL,</match>
    <description>RDS DDL 쿼리 탐지 - DB 구조 변경</description>
    <group>ddl,database_change</group>
  </rule>

  <!-- WRITE 탐지 -->
  <rule id="100102" level="5">
    <if_sid>100100</if_sid>
    <match>,WRITE,</match>
    <description>RDS WRITE 쿼리 탐지 - 데이터 변경</description>
    <group>write,database_change</group>
  </rule>

  <!-- READ 탐지 -->
  <rule id="100103" level="3">
    <if_sid>100100</if_sid>
    <match>,READ,</match>
    <description>RDS SELECT 쿼리 탐지 - 데이터 조회</description>
    <group>read</group>
  </rule>

  <!-- rdsproxyadmin 헬스체크 필터링 -->
  <rule id="100104" level="0">
    <if_sid>100103</if_sid>
    <match>rdsproxyadmin</match>
    <description>RDS Proxy 헬스체크 SELECT - 무시</description>
    <group>noise</group>
  </rule>

  <!-- 업무 시간 외 WRITE -->
  <rule id="100105" level="10">
    <if_sid>100102</if_sid>
    <time>09:00 - 00:00</time>
    <description>업무 시간 외 RDS WRITE 쿼리 탐지 - 비정상 접근 의심</description>
    <group>after_hours,database_change</group>
  </rule>

  <!-- 업무 시간 외 DDL -->
  <rule id="100106" level="12">
    <if_sid>100101</if_sid>
    <time>09:00 - 00:00</time>
    <description>업무 시간 외 RDS DDL 쿼리 탐지 - 비정상 접근 의심</description>
    <group>after_hours,ddl</group>
  </rule>

  <!-- DROP 단독 탐지 -->
  <rule id="100107" level="14">
    <if_sid>100101</if_sid>
    <match>,DROP </match>
    <description>RDS DROP 쿼리 탐지 - 데이터 삭제 위험</description>
    <group>ddl,critical</group>
  </rule>

  <!-- ROLE 권한 변경 탐지 (GRANT/REVOKE/CREATE ROLE) -->
  <rule id="100108" level="10">
    <if_sid>100100</if_sid>
    <match>,ROLE,</match>
    <description>RDS 권한 변경 탐지 (GRANT/REVOKE/CREATE ROLE)</description>
    <group>privilege_escalation,role_change</group>
  </rule>

  <!-- 업무시간 외 ROLE 변경 -->
  <rule id="100109" level="12">
    <if_sid>100108</if_sid>
    <time>18:00 - 09:00</time>
    <description>업무시간 외 권한 변경 탐지 - 계정 탈취 의심</description>
    <group>after_hours,privilege_escalation</group>
  </rule>

  <!-- CREATE ROLE 단독 탐지 (신규 DB 계정 생성) -->
  <rule id="100110" level="12">
    <if_sid>100108</if_sid>
    <match>CREATE ROLE</match>
    <description>RDS 신규 DB 계정 생성 탐지 - persistence 의심</description>
    <group>account_management,persistence</group>
  </rule>


  <!-- 슬로우 쿼리 탐지 -->
  <rule id="100112" level="6">
    <location>Wazuh-AWS</location>
    <match>duration: </match>
    <description>RDS 슬로우 쿼리 탐지 (1초 이상 소요 쿼리)</description>
    <group>performance,slow_query,</group>
  </rule>

  <!-- 접속 기록 탐지 -->
  <rule id="100113" level="3">
    <location>Wazuh-AWS</location>
    <match>connection received</match>
    <description>RDS 클라이언트 접속 기록</description>
    <group>authentication,connection,</group>
  </rule>

  <!-- rdsproxyadmin WRITE 필터링 -->
  <rule id="100114" level="0">
    <if_sid>100102</if_sid>
    <match>rdsproxyadmin</match>
    <description>RDS Proxy 내부 WRITE - 무시</description>
    <group>noise,</group>
  </rule>



  <!-- 대용량 SELECT 탐지 — 데이터 유출 의심 -->
  <rule id="100115" level="10">
    <if_sid>100103</if_sid>
    <field name="data.audit.rows" type="pcre2">^[1-9][0-9]{4,}</field>
    <description>내부자 위협 의심 — 대용량 SELECT (10000건 이상)</description>
    <group>rds,insider_threat,data_exfiltration</group>
    <mitre><id>T1530</id></mitre>
  </rule>

  <!-- 1분 내 SELECT 반복 — 대량 데이터 추출 의심 -->
  <rule id="100116" level="12" frequency="100" timeframe="60">
    <if_matched_sid>100103</if_matched_sid>
    <description>내부자 위협 의심 — 1분 내 SELECT 100회 이상</description>
    <group>rds,insider_threat,data_exfiltration</group>
    <mitre><id>T1530</id></mitre>
  </rule>

  <!-- rdsproxyadmin READ 필터링 (기존 100104와 동일 패턴) -->
  <!-- Vault 동적 역할 READ 필터링 — 복제/내부 동작 노이즈 제거 -->
  <rule id="100117" level="0">
    <if_sid>100103</if_sid>
    <match>v-approle-api-role</match>
    <description>Vault 동적 역할 SELECT - 무시</description>
    <group>noise</group>
  </rule>

  <!-- DB 브루트포스 — 1분 내 로그인 실패 10회 -->
  <rule id="100118" level="12" frequency="10" timeframe="60">
    <if_matched_sid>100100</if_matched_sid>
    <match>FAILED_AUTHENTICATION|authentication failed</match>
    <description>DB 브루트포스 의심 — 1분 내 로그인 실패 10회</description>
    <group>rds,bruteforce,authentication</group>
    <mitre><id>T1110</id></mitre>
  </rule>

  <!-- Vault 동적 역할 CREATE ROLE 무시 -->
  <rule id="100119" level="0">
    <if_sid>100110</if_sid>
    <match>v-approle-api-role</match>
    <description>Vault 동적 역할 CREATE ROLE - 무시</description>
    <group>noise</group>
  </rule>

  <!-- Vault 동적 역할  GRANT/REVOKE 무시 -->
  <rule id="100120" level="0">
      <if_sid>100108</if_sid>
      <match>v-approle-api-role</match>
      <description>Vault 동적 역할 ROLE 변경 - 무시</description>
      <group>noise</group>
  </rule>

  <rule id="100121" level="0">
      <if_sid>5503</if_sid>
      <match>ssm-user</match>
      <description>SSM Agent PAM 실패 — 노이즈 제거</description>
      <group>noise</group>
  </rule>



</group>