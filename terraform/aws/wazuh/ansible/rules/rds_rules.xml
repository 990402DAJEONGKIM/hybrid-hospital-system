# rds_rules.xml
<group name="rds,pgaudit,">

  <!-- RDS pgaudit 기본 탐지 (부모 룰) -->
  <!-- RDS pgaudit 베이스 룰 - 260611 김강환 -->
  <!-- if_sid>2502 + match로 RDS 로그 식별 -->
  <rule id="100100" level="3">
    <if_sid>2502</if_sid>
    <match>AUDIT: SESSION</match>
    <description>RDS pgaudit 감사 로그</description>
    <group>rds,pgaudit,</group>
  </rule>

  <!-- DDL 탐지 -->
  <rule id="100101" level="10">
    <if_sid>100100</if_sid>
    <match>,DDL,</match>
    <description>RDS DDL 쿼리 탐지 - DB 구조 변경</description>
    <group>ddl,database_change</group>
  </rule>

  <rule id="100102" level="2">
    <if_sid>100100</if_sid>
    <match>,WRITE,</match>
    <description>RDS WRITE 쿼리 탐지 - 데이터 변경</description>
    <group>write,database_change</group>
    <options>no_log</options>
  </rule>

  <rule id="100103" level="2">
   <if_sid>100100</if_sid>
    <match>,READ,</match>
    <description>RDS SELECT 쿼리 탐지 - 데이터 조회</description>
    <group>read</group>
    <options>no_log</options>
  </rule>
  <!-- rdsproxyadmin 헬스체크 필터링 -->
  <rule id="100104" level="0">
    <if_sid>100103</if_sid>
    <match>rdsproxyadmin</match>
    <description>RDS Proxy 헬스체크 SELECT - 무시</description>
    <group>noise</group>
  </rule>

  <!-- 주말 RDS WRITE (24시간) -->
  <rule id="100122" level="10">
    <if_sid>100102</if_sid>
    <weekday>saturday,sunday</weekday>
    <description>주말 RDS WRITE 쿼리 탐지 - 비정상 접근 의심</description>
    <group>after_hours,database_change,weekend,</group>
  </rule>

  <!-- 업무 시간 외 WRITE -->
  <rule id="100105" level="10">
    <if_sid>100102</if_sid>
    <time>9 am - 12 am</time>
    <description>업무 시간 외 RDS WRITE 쿼리 탐지 - 비정상 접근 의심</description>
    <group>after_hours,database_change</group>
  </rule>

  <!-- 주말 RDS DDL (24시간) -->
  <rule id="100123" level="12">
    <if_sid>100101</if_sid>
    <weekday>saturday,sunday</weekday>
    <description>주말 RDS DDL 쿼리 탐지 - 비정상 접근 의심</description>
    <group>after_hours,ddl,weekend,</group>
  </rule>

  <!-- 업무 시간 외 DDL -->
  <rule id="100106" level="12">
    <if_sid>100101</if_sid>
    <time>9 am - 12 am</time>
    <description>업무 시간 외 RDS DDL 쿼리 탐지 - 비정상 접근 의심</description>
    <group>after_hours,ddl</group>
  </rule>

  <!-- DROP 단독 탐지 -->
  <rule id="100107" level="14">
    <if_sid>100101</if_sid>
    <match>,DROP </match>
    <description>RDS DROP 쿼리 탐지 - 데이터 삭제 위험</description>
    <group>ddl,critical</group>
  </rule>

  <!-- ROLE 권한 변경 탐지 (GRANT/REVOKE/CREATE ROLE) -->
  <rule id="100108" level="10">
    <if_sid>100100</if_sid>
    <match>,ROLE,</match>
    <description>RDS 권한 변경 탐지 (GRANT/REVOKE/CREATE ROLE)</description>
    <group>privilege_escalation,role_change</group>
  </rule>

  <!-- 주말 RDS ROLE 변경 (24시간) -->
  <rule id="100124" level="12">
    <if_sid>100108</if_sid>
    <weekday>saturday,sunday</weekday>
    <description>주말 권한 변경 탐지 - 계정 탈취 의심</description>
    <group>after_hours,privilege_escalation,weekend,</group>
  </rule>

  <!-- 업무시간 외 ROLE 변경 -->
  <rule id="100109" level="12">
    <if_sid>100108</if_sid>
    <time>9 am - 12 am</time>
    <description>업무시간 외 권한 변경 탐지 - 계정 탈취 의심</description>
    <group>after_hours,privilege_escalation</group>
  </rule>

  <!-- CREATE ROLE 단독 탐지 (신규 DB 계정 생성) -->
  <rule id="100110" level="12">
    <if_sid>100108</if_sid>
    <match>CREATE ROLE</match>
    <description>RDS 신규 DB 계정 생성 탐지 - persistence 의심</description>
    <group>account_management,persistence</group>
  </rule>


  <!-- 슬로우 쿼리 탐지 - 수정 260611 김강환 -->
  <rule id="100112" level="6">
    <if_sid>2502</if_sid>
    <match>duration: </match>
    <description>RDS 슬로우 쿼리 탐지</description>
    <group>rds,performance,slow_query,</group>
  </rule>

  <!-- 접속 기록 탐지 - 수정 260611 김강환 -->
  <rule id="100113" level="3">
    <if_sid>2502</if_sid>
    <match>connection received</match>
    <description>RDS 클라이언트 접속 기록</description>
    <group>rds,authentication,connection,</group>
  </rule>

  <!-- rdsproxyadmin WRITE 필터링 -->
  <rule id="100114" level="0">
    <if_sid>100102</if_sid>
    <match>rdsproxyadmin</match>
    <description>RDS Proxy 내부 WRITE - 무시</description>
    <group>noise,</group>
  </rule>



  <!-- 대용량 SELECT 탐지 — 데이터 유출 의심 -->
  <rule id="100115" level="10">
    <if_sid>100103</if_sid>
    <field name="data.audit.rows" type="pcre2">^[1-9][0-9]{4,}</field>
    <description>내부자 위협 의심 — 대용량 SELECT (10000건 이상)</description>
    <group>rds,insider_threat,data_exfiltration</group>
    <mitre><id>T1530</id></mitre>
  </rule>

  <!-- 1분 내 SELECT 반복 — 대량 데이터 추출 의심 -->
  <rule id="100116" level="12" frequency="100" timeframe="60">
    <if_matched_sid>100103</if_matched_sid>
    <description>내부자 위협 의심 — 1분 내 SELECT 100회 이상</description>
    <group>rds,insider_threat,data_exfiltration</group>
    <mitre><id>T1530</id></mitre>
  </rule>

  <!-- rdsproxyadmin READ 필터링 (기존 100104와 동일 패턴) -->
  <!-- Vault 동적 역할 READ 필터링 — 복제/내부 동작 노이즈 제거 -->
  <rule id="100117" level="0">
    <if_sid>100103</if_sid>
    <match>v-approle-api-role</match>
    <description>Vault 동적 역할 SELECT - 무시</description>
    <group>noise</group>
  </rule>

  <!-- DB 브루트포스 — 1분 내 로그인 실패 10회 -->
  <rule id="100118" level="12" frequency="10" timeframe="60">
    <if_matched_sid>100100</if_matched_sid>
    <match>FAILED_AUTHENTICATION|authentication failed</match>
    <description>DB 브루트포스 의심 — 1분 내 로그인 실패 10회</description>
    <group>rds,bruteforce,authentication</group>
    <mitre><id>T1110</id></mitre>
  </rule>

  <!-- Vault 동적 역할 CREATE ROLE 무시 -->
  <rule id="100119" level="0">
    <if_sid>100110</if_sid>
    <match>v-approle-api-role</match>
    <description>Vault 동적 역할 CREATE ROLE - 무시</description>
    <group>noise</group>
  </rule>

  <!-- Vault 동적 역할  GRANT/REVOKE 무시 -->
  <rule id="100120" level="0">
      <if_sid>100108</if_sid>
      <match>v-approle-api-role</match>
      <description>Vault 동적 역할 ROLE 변경 - 무시</description>
      <group>noise</group>
  </rule>

  <rule id="100121" level="0">
      <if_sid>5503</if_sid>
      <match>ssm-user</match>
      <description>SSM Agent PAM 실패 — 노이즈 제거</description>
      <group>noise</group>
  </rule>


  <!-- Keycloak 마이그레이션 DDL 무시 -->
  <rule id="100125" level="0">
    <if_sid>100101</if_sid>
    <match>keycloak@keycloak</match>
    <description>Keycloak 마이그레이션 DDL - 무시</description>
    <group>noise</group>
  </rule>

  <!-- Keycloak DROP 무시 -->
  <rule id="100126" level="0">
    <if_sid>100107</if_sid>
    <match>keycloak@keycloak</match>
    <description>Keycloak 마이그레이션 DROP - 무시</description>
    <group>noise</group>
  </rule>

  <!-- Keycloak SELECT 대량 조회 무시 -->
  <rule id="100127" level="0">
    <if_sid>100116</if_sid>
    <match>keycloak@keycloak</match>
    <description>Keycloak 내부 SELECT 대량 조회 - 무시</description>
    <group>noise</group>
  </rule>


  <!-- Keycloak 사용자 생성 무시 -->
  <rule id="100128" level="0">
    <if_sid>100110</if_sid>
    <match>keycloak</match>
    <description>Keycloak DB 사용자 생성 - 무시</description>
    <group>noise</group>
  </rule>


  <!-- Keycloak ROLE/GRANT 무시 -->
  <rule id="100129" level="0">
    <if_sid>100108</if_sid>
    <match>keycloak</match>
    <description>Keycloak GRANT/ROLE 변경 - 무시</description>
    <group>noise</group>
  </rule>


  <!-- 업무시간 외 RDS SELECT - 내부자 위협 의심 - 260609 김강환 -->
  <rule id="100130" level="10">
    <if_sid>100103</if_sid>
    <time>9 am - 12 am</time>
    <description>업무시간 외 RDS SELECT 탐지 - 내부자 위협 의심</description>
    <group>after_hours,insider_threat,</group>
    <mitre><id>T1530</id></mitre>
  </rule>

  <!-- 주말 RDS SELECT - 내부자 위협 의심 - 260609 김강환 -->
  <rule id="100131" level="10">
    <if_sid>100103</if_sid>
    <weekday>saturday,sunday</weekday>
    <description>주말 RDS SELECT 탐지 - 내부자 위협 의심</description>
    <group>after_hours,insider_threat,weekend,</group>
    <mitre><id>T1530</id></mitre>
  </rule>

  <!-- rdsadmin 로컬 접속 기록 억제 - 260611 김강환 -->
  <!-- host=[local] 패턴 = Aurora 내부 관리 프로세스 정상 동작 -->
  <rule id="100132" level="0">
    <if_sid>100113</if_sid>
    <match>host=[local]</match>
    <description>RDS 로컬 내부 접속 — 무시</description>
    <group>noise</group>
  </rule>

  <!-- rdsadmin connection authorized 2502 억제 - 260611 김강환 -->
  <!-- Aurora 내부 rdsadmin 프로세스 로그 -->
  <rule id="100133" level="0">
    <if_sid>2502</if_sid>
    <match>rdsadmin</match>
    <description>RDS rdsadmin 내부 프로세스 로그 — 무시</description>
    <group>noise</group>
  </rule>

  <!-- RDS Proxy 내부 헬스체크 계정 로그 억제 - 추가 260611 김강환 -->
  <!-- rdsproxyadmin: RDS Proxy가 백엔드 RDS 연결 상태 확인하는 내부 계정 -->
  <rule id="100134" level="0">
    <if_sid>2502</if_sid>
    <match>rdsproxyadmin</match>
    <description>RDS Proxy 내부 헬스체크 로그 — 무시</description>
    <group>noise</group>
  </rule>

  <!-- GCP rds-proxy 정상 연결 억제 - 추가 260611 김강환 -->
  <!-- 10.10.1.37 = GCP rds-proxy → AWS RDS TCP 포워딩 정상 동작 -->
  <rule id="100135" level="0">
    <if_sid>100113</if_sid>
    <match>host=10.10.1.37</match>
    <description>GCP rds-proxy 정상 연결 — 무시</description>
    <group>noise</group>
  </rule>

  <!-- 온프레미스 서버 RDS 접속 억제 - 추가 260611 김강환 -->
  <rule id="100136" level="0">
    <if_sid>100113</if_sid>
    <match>host=172.30.1.76</match>
    <description>온프레미스 서버 RDS 정상 연결 — 무시</description>
    <group>noise</group>
  </rule>

  <!-- 모니터링 서버 RDS 접속 억제 - 추가 260611 김강환 -->
  <rule id="100137" level="0">
    <if_sid>100113</if_sid>
    <match>host=10.0.12.128</match>
    <description>모니터링 서버 RDS 정상 연결 — 무시</description>
    <group>noise</group>
  </rule>

  <!-- SELECT 1 헬스체크 억제 - 추가 260611 김강환 -->
  <!-- ECS FastAPI 커넥션 풀 헬스체크 정상 동작 -->
  <rule id="100138" level="0">
    <if_sid>100103</if_sid>
    <match>SELECT 1</match>
    <description>DB 커넥션 풀 헬스체크 SELECT 1 — 무시</description>
    <group>noise</group>
  </rule>

  <!-- Vault 동적 역할 실제 인증 실패 탐지 - 추가 260611 김강환 -->
  <!-- Role이 존재하는데 인증 실패 = 자격증명 탈취 의심 -->
  <rule id="100140" level="10">
    <if_sid>2502</if_sid>
    <regex>v-approle-api-role\.+FATAL</regex>
    <description>Vault 동적 역할 DB 인증 실패</description>
    <group>rds,vault,credential_theft</group>
    <mitre><id>T1078</id></mitre>
  </rule>


  <!-- Keycloak RDS 연결 끊김 억제 - 추가 260611 김강환 -->
  <rule id="100142" level="0">
    <if_sid>2502</if_sid>
    <match>keycloak@keycloak</match>
    <description>Keycloak RDS 연결 끊김 — 무시</description>
    <group>noise</group>
  </rule>

  <!-- 대량 RDS WRITE 탐지 - 추가 260612 김강환 -->
  <!-- 1분 내 100건 이상 WRITE → 해킹/내부자 위협 의심 -->
  <rule id="100145" level="12" frequency="100" timeframe="60">
    <if_matched_sid>100102</if_matched_sid>
    <description>RDS 대량 WRITE 탐지 — 해킹/내부자 위협 의심</description>
    <group>rds,database_attack,insider_threat</group>
    <mitre><id>T1485</id></mitre>
  </rule>

  <!-- 대량 RDS SELECT 탐지 - 추가 260612 김강환 -->
  <!-- 1분 내 100건 이상 SELECT → 데이터 유출 의심 -->
  <rule id="100146" level="12" frequency="100" timeframe="60">
    <if_matched_sid>100103</if_matched_sid>
    <description>RDS 대량 SELECT 탐지 — 데이터 유출 의심</description>
    <group>rds,data_exfiltration,insider_threat</group>
    <mitre><id>T1530</id></mitre>
  </rule>

</group>