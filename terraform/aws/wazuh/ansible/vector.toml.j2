# =============================================================
# Vector 설정 - Wazuh alerts.json + archives.json → S3 백업
# ISMS-P 2.9.1 로그 보존 목적
# =============================================================

data_dir = "/var/lib/vector"

[api]
enabled = true
address = "127.0.0.1:8686"

# ── alerts 소스 ───────────────────────────────────────────────
# 룰 매칭된 보안 이벤트만 수집 (실시간)
[sources.wazuh_alerts]
type = "file"
include = ["/var/ossec/logs/alerts/alerts.json"]
read_from = "end"
glob_minimum_cooldown_ms = 1000
rotate_wait_secs = 5
ignore_older_secs = 86400



# ── alerts S3 sink ────────────────────────────────────────────
[sinks.s3_backup]
type = "aws_s3"
inputs = ["wazuh_alerts"]
bucket = "aws-k2p-storage-01"
region = "ap-south-2"
key_prefix = "wazuh/alerts/%Y/%m/%d/"
filename_time_format = "alerts-%Y-%m-%d-%H-%M"
filename_extension = "json.gz"
filename_append_uuid = false
compression = "gzip"

[sinks.s3_backup.encoding]
codec = "text"

[sinks.s3_backup.batch]
timeout_secs = 300
max_bytes = 10737418242

[sinks.s3_backup.buffer]
type = "disk"
max_size = 1073741824
when_full = "block"



# ── audit_archive 그룹만 필터 (온프레미스 감사) - 260608 김강환 ──
[transforms.audit_archive]
type = "filter"
inputs = ["wazuh_alerts"]
condition = 'contains(string!(.rule.groups), "audit_archive")'

# ── 온프레미스 감사 S3 보존 ──
[sinks.s3_audit]
type = "aws_s3"
inputs = ["audit_archive"]
bucket = "aws-k2p-storage-01"
region = "ap-south-2"
key_prefix = "onprem/%Y/%m/%d/"
filename_time_format = "audit-%Y-%m-%d-%H-%M"
filename_extension = "json.gz"
filename_append_uuid = false
compression = "gzip"

[sinks.s3_audit.encoding]
codec = "text"

[sinks.s3_audit.batch]
timeout_secs = 300
max_bytes = 10737418242

[sinks.s3_audit.buffer]
type = "disk"
max_size = 1073741824
when_full = "block"